# ===== AI gateway (OpenAI-compatible) =====
# Any OpenAI-compatible /chat/completions endpoint works (OpenAI, Azure, a local
# gateway, etc.). Fill in your own base URL, key and model.
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_ENABLED=true

# ===== Database =====
DATABASE_URL=sqlite:///./scholarpulse.db

# ===== Optional: Semantic Scholar API key (works without one, just stricter rate limits) =====
SEMANTIC_SCHOLAR_KEY=

# ===== Optional: GitHub token (raises the repo-search rate limit) =====
GITHUB_TOKEN=

# ===== Email (SMTP; leave blank to disable email digests) =====
# Gmail example: SMTP_HOST=smtp.gmail.com  SMTP_PORT=587
# SMTP_USER=you@gmail.com  SMTP_PASS=<app password>  (use a Gmail App Password, not your login)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# ===== Optional push channels (enable the channel in Settings, then fill creds here) =====
# Telegram: create a bot via @BotFather → token; get your chat id via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Slack: Incoming Webhook URL
SLACK_WEBHOOK_URL=
# WeChat via Server酱 (https://sct.ftqq.com) — your SendKey, e.g. SCTxxxx
SERVERCHAN_KEY=

# ===== Scheduling =====
# Daily refresh times (comma-separated, local time); default 10:00 + 22:00
REFRESH_TIMES=10:00,22:00
TIMEZONE=Asia/Shanghai
# When a keyword has no new papers today, backfill the latest N
BACKFILL_N=5

# ===== Academic-news RSS feeds (comma-separated) =====
RSS_FEEDS=http://export.arxiv.org/rss/cs.PL
